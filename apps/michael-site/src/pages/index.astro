<script>
  (() => {
    const overlay = document.getElementById('page-overlay');
    const cta = document.getElementById('overlay-cta');

    function reveal(scrollTarget?: string) {
      cta.disabled = true;
      // Snap to top instantly so the hero animation is in view
      window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
      overlay.classList.add('revealed');
      setTimeout(() => { overlay.style.display = 'none'; }, 950);

      // Start chat slide-in while overlay is still fading — visible cascade effect
      setTimeout(() => {
        const heroLeft = document.getElementById('hero-left');
        if (heroLeft) heroLeft.classList.add('chat-revealed');
      }, 300);

      if (scrollTarget) {
        setTimeout(() => {
          const el = document.getElementById(scrollTarget);
          if (el) el.scrollIntoView({ behavior: 'smooth' });
        }, 1100);
      } else if (window.innerWidth < 1024) {
        // On mobile, scroll so the bottom of the chat iframe is visible (exposes input bar)
        setTimeout(() => {
          const chatEl = document.getElementById('hero-chat');
          if (chatEl) chatEl.scrollIntoView({ behavior: 'smooth', block: 'end' });
        }, 950);
      }
    }

    cta.addEventListener('click', () => reveal());

    document.getElementById('overlay-schedule').addEventListener('click', (e) => {
      e.preventDefault();
      reveal();
      setTimeout(() => {
        if (window.Calendly) Calendly.initPopupWidget({url: 'https://calendly.com/mike-ageniusailabs/30min'});
      }, 400);
    });

    document.getElementById('overlay-see-work').addEventListener('click', (e) => {
      e.preventDefault();
      reveal('work');
    });

  })();
</script>
