# ============================================================================
# RAG Portfolio Chat — environment configuration
# Copy to .env and fill in your values.
# ============================================================================

# --- Persona (drives the system prompt + welcome message) ---
OWNER_NAME=Your Name
OWNER_ROLE=Your Title (e.g. "Director of AI")
OWNER_BIO=One-paragraph bio. Keep it tight. This gets injected into the system prompt and shapes every reply.

# --- Qdrant (self-hosted vector DB) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=public_kb

# --- OpenAI (embeddings) ---
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-large

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=

# --- ElevenLabs (optional TTS) ---
# Default voice ID below is the stock "Adam" voice. Use any ElevenLabs voice you have access to.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- Booking link shown in the chat UI ---
CALENDAR_BOOKING_URL=

# --- CORS — set to your production origin in prod, e.g. https://example.com ---
ALLOWED_ORIGIN=*
