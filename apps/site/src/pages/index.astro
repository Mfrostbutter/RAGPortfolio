---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const { owner, hero, about, work, chat, links } = site;
---
<BaseLayout>
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">{owner.role}</p>
          <h1>{owner.name}</h1>
          <p class="tagline">{owner.tagline}</p>
          <p class="pitch">{hero.pitch}</p>
          {hero.secondary && <p class="pitch secondary">{hero.secondary}</p>}
          <div class="cta-row">
            <a class="btn primary" href={hero.ctaPrimary.href}>{hero.ctaPrimary.label}</a>
            <a class="btn ghost" href={hero.ctaSecondary.href}>{hero.ctaSecondary.label}</a>
          </div>
        </div>
        <div class="hero-portrait">
          <img src={owner.headshot} alt={`${owner.name} headshot`} />
        </div>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="section">
      <h2>{about.heading}</h2>
      {about.body.map((p) => <p class="body">{p}</p>)}
    </section>

    <!-- Work -->
    <section id="work" class="section">
      <h2>{work.heading}</h2>
      <div class="work-grid">
        {work.projects.map((p) => (
          <a class="card" href={p.href}>
            <h3>{p.title}</h3>
            <p>{p.blurb}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Chat -->
    <section id="chat" class="section chat-section">
      <h2>{chat.heading}</h2>
      <div class="chat-frame">
        <iframe
          src={chat.iframeUrl}
          title="RAG portfolio chat"
          height={chat.height}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <span>&copy; {new Date().getFullYear()} {owner.name}</span>
        <div class="footer-links">
          {links.linkedin && <a href={links.linkedin}>LinkedIn</a>}
          {links.github && <a href={links.github}>GitHub</a>}
          {links.email && <a href={`mailto:${links.email}`}>Email</a>}
          {links.booking && <a href={links.booking}>Book a call</a>}
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 6rem 0 4rem;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }
  .eyebrow {
    font-family: 'Martian Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted, #5a5a6a);
    margin: 0 0 1rem;
  }
  h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin: 0 0 1rem;
  }
  .tagline {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink, #0f0f14);
    margin: 0 0 1.5rem;
  }
  .pitch {
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--muted, #5a5a6a);
    max-width: 52ch;
    margin: 0 0 1rem;
  }
  .pitch.secondary { margin-bottom: 2rem; }

  .cta-row { display: flex; gap: 0.75rem; margin-top: 1rem; }
  .btn {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.15s ease;
  }
  .btn.primary { background: var(--accent, #2b6ff0); color: white; }
  .btn.primary:hover { transform: translateY(-1px); }
  .btn.ghost {
    background: transparent;
    color: var(--ink, #0f0f14);
    border: 1px solid rgba(0,0,0,0.15);
  }

  .hero-portrait img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  /* Sections */
  .section {
    padding: 5rem 0;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    margin: 0 0 2rem;
  }
  .body {
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 62ch;
    margin: 0 0 1rem;
  }

  /* Work */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .card {
    display: block;
    padding: 1.75rem;
    border-radius: 12px;
    background: rgba(0,0,0,0.03);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }
  .card:hover { background: rgba(0,0,0,0.06); }
  .card h3 { margin: 0 0 0.5rem; font-size: 1.2rem; }
  .card p { margin: 0; color: var(--muted, #5a5a6a); font-size: 0.95rem; line-height: 1.5; }

  /* Chat */
  .chat-section .chat-frame {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.08);
    background: white;
  }
  .chat-frame iframe { width: 100%; border: 0; display: block; }

  /* Footer */
  .footer { padding: 3rem 0 4rem; border-top: 1px solid rgba(0,0,0,0.08); margin-top: 2rem; }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--muted, #5a5a6a);
  }
  .footer-links { display: flex; gap: 1.25rem; }
  .footer-links a { color: inherit; text-decoration: none; }
  .footer-links a:hover { color: var(--accent, #2b6ff0); }

  /* Mobile */
  @media (max-width: 768px) {
    main { padding: 0 1.25rem; }
    .hero { min-height: auto; padding: 4rem 0 3rem; }
    .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero-portrait { order: -1; max-width: 220px; }
    .section { padding: 3rem 0; }
  }
</style>
