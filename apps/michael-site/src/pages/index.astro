<style>
  /* Full-page frosted overlay */
  .page-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    background: rgba(0, 0, 0, 0.96);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 1;
    transition: opacity 0.85s ease;
  }
  .page-overlay.revealed {
    opacity: 0;
    pointer-events: none;
  }

  .overlay-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    max-width: 420px;
    width: 100%;
  }

  .overlay-avatar {
    width: 134px;
    height: 134px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top center;
    border: 2px solid rgba(255, 255, 255, 0.28);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.55), 0 0 0 6px rgba(255, 255, 255, 0.06);
  }

  .overlay-name {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144;
    font-size: 44px;
    font-weight: 400;
    color: #fff;
    letter-spacing: -0.035em;
    line-height: 1;
    margin-top: 8px;
  }

  .overlay-role {
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .overlay-links {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .overlay-link {
    color: var(--accent);
    font-size: 13px;
    font-weight: 500;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: rgba(194, 77, 44, 0.5);
    transition: opacity 0.15s;
    cursor: pointer;
  }
  .overlay-link:hover { opacity: 0.72; }
  .overlay-link-sep { color: rgba(255, 255, 255, 0.3); font-size: 11px; }

  .overlay-cta {
    margin-top: 10px;
    background: var(--paper);
    color: var(--ink);
    border: none;
    padding: 14px 40px;
    border-radius: 2px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease;
    min-width: 180px;
  }
  .overlay-cta:hover { background: var(--accent); color: var(--paper); transform: translateY(-1px); }
  .overlay-cta:active { transform: translateY(0); }
